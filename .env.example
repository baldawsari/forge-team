# =============================================================================
# ForgeTeam Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- AI Provider Keys ---
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
GOOGLE_AI_API_KEY=REPLACE_ME

# --- Database ---
DATABASE_URL=postgresql://forgeteam:forgeteam_secret@localhost:5432/forgeteam
POSTGRES_DB=forgeteam
POSTGRES_USER=forgeteam
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Server Ports ---
PORT=18789
DASHBOARD_PORT=3000

# --- Environment ---
NODE_ENV=development

# --- Optional: Voice & Speech ---
ELEVENLABS_API_KEY=REPLACE_ME
WHISPER_API_KEY=REPLACE_ME

# --- Optional: Qdrant Vector DB ---
QDRANT_URL=http://localhost:6333
